prefix_rule(pattern=["git", "push", ["-f", "--force", "--force-with-lease", "--force-if-includes"]], decision="forbidden")
prefix_rule(pattern=["git", ["status", "diff", "log", "show"]], decision="allow")
prefix_rule(pattern=["rtk git", "push", ["-f", "--force", "--force-with-lease", "--force-if-includes"]], decision="forbidden")
prefix_rule(pattern=["rtk git", ["status", "diff", "log", "show"]], decision="allow")
prefix_rule(pattern = ["rg"], decision = "allow")
prefix_rule(pattern = ["find"], decision = "allow")
prefix_rule(pattern = ["ls"], decision = "allow")
prefix_rule(pattern = ["pwd"], decision = "allow")
prefix_rule(pattern = ["tree"], decision = "allow")
prefix_rule(pattern = ["wc"], decision = "allow")
prefix_rule(pattern = ["rtk rg"], decision = "allow")
prefix_rule(pattern = ["rtk find"], decision = "allow")
prefix_rule(pattern = ["rtk ls"], decision = "allow")
prefix_rule(pattern = ["rtk pwd"], decision = "allow")
prefix_rule(pattern = ["rtk tree"], decision = "allow")
prefix_rule(pattern = ["rtk wc"], decision = "allow")
