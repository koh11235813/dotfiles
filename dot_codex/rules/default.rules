# Keep this file limited to durable command policy. One-off approvals written by
# the TUI should be reviewed instead of being promoted automatically.

# RTK bootstrap and read-only inspection tools.
prefix_rule(
    pattern = ["command", "-v", "rtk"],
    decision = "allow",
    justification = "Locate the required RTK command without prompting.",
    match = ["command -v rtk"],
    not_match = ["command -v git"],
)

prefix_rule(
    pattern = ["rtk", ["rg", "grep", "ls", "pwd", "tree", "wc", "which"]],
    decision = "allow",
    justification = "Allow RTK-wrapped read-only workspace inspection commands.",
    match = [
        "rtk rg --files",
        "rtk ls -la",
        "rtk which gitleaks",
    ],
    not_match = [
        "rtk find . -type f",
        "rtk sed -n 1,80p README.md",
    ],
)

# Git commands that inspect repository state without intentionally changing it.
prefix_rule(
    pattern = [
        "rtk",
        "git",
        [
            "status",
            "diff",
            "log",
            "show",
            "ls-files",
            "show-ref",
            "rev-list",
            "rev-parse",
            "ls-tree",
            "grep",
        ],
    ],
    decision = "allow",
    justification = "Allow RTK-wrapped Git inspection and diagnostics.",
    match = [
        "rtk git status --short --branch",
        "rtk git diff --stat",
        "rtk git rev-list --all --objects",
    ],
    not_match = [
        "rtk git commit -m change",
        "git status --short",
    ],
)

prefix_rule(
    pattern = ["rtk", "git", "stash", ["list", "show"]],
    decision = "allow",
    justification = "Inspect stashes without changing or deleting them.",
    match = [
        "rtk git stash list",
        "rtk git stash show --stat stash@{0}",
    ],
    not_match = ["rtk git stash drop stash@{0}"],
)

# Require confirmation for deletion and Git operations that can discard work.
prefix_rule(
    pattern = ["rm"],
    decision = "prompt",
    justification = "Confirm file deletion before running rm outside the sandbox.",
    match = ["rm -rf build"],
    not_match = ["rtk rm -rf build"],
)

prefix_rule(
    pattern = ["rtk", "rm"],
    decision = "prompt",
    justification = "Confirm file deletion before running RTK-wrapped rm outside the sandbox.",
    match = ["rtk rm -rf build"],
    not_match = ["rm -rf build"],
)

prefix_rule(
    pattern = ["git", ["reset", "clean", "restore", "prune", "gc"]],
    decision = "prompt",
    justification = "Confirm Git operations that can discard work or unreachable history.",
    match = [
        "git reset --hard HEAD~1",
        "git clean -fd",
        "git restore README.md",
    ],
    not_match = ["git status --short"],
)

prefix_rule(
    pattern = ["rtk", "git", ["reset", "clean", "restore", "prune", "gc"]],
    decision = "prompt",
    justification = "Confirm RTK-wrapped Git operations that can discard work or unreachable history.",
    match = [
        "rtk git reset --hard HEAD~1",
        "rtk git clean -fd",
        "rtk git restore README.md",
    ],
    not_match = ["rtk git status --short"],
)

prefix_rule(
    pattern = ["git", "branch", ["-d", "-D", "--delete"]],
    decision = "prompt",
    justification = "Confirm branch deletion before removing a local branch.",
    match = ["git branch -D obsolete"],
    not_match = ["git branch --list"],
)

prefix_rule(
    pattern = ["rtk", "git", "branch", ["-d", "-D", "--delete"]],
    decision = "prompt",
    justification = "Confirm RTK-wrapped branch deletion before removing a local branch.",
    match = ["rtk git branch -D obsolete"],
    not_match = ["rtk git branch --list"],
)

prefix_rule(
    pattern = ["git", "stash", ["pop", "drop", "clear"]],
    decision = "prompt",
    justification = "Confirm operations that remove entries from the stash.",
    match = ["git stash drop stash@{0}"],
    not_match = ["git stash list"],
)

prefix_rule(
    pattern = ["rtk", "git", "stash", ["pop", "drop", "clear"]],
    decision = "prompt",
    justification = "Confirm RTK-wrapped operations that remove entries from the stash.",
    match = ["rtk git stash drop stash@{0}"],
    not_match = ["rtk git stash list"],
)

prefix_rule(
    pattern = ["git", "reflog", ["expire", "delete"]],
    decision = "prompt",
    justification = "Confirm deletion of reflog history.",
    match = ["git reflog expire --expire=now --all"],
    not_match = ["git reflog show"],
)

prefix_rule(
    pattern = ["rtk", "git", "reflog", ["expire", "delete"]],
    decision = "prompt",
    justification = "Confirm RTK-wrapped deletion of reflog history.",
    match = ["rtk git reflog expire --expire=now --all"],
    not_match = ["rtk git reflog show"],
)

prefix_rule(
    pattern = ["git", "checkout", "--"],
    decision = "prompt",
    justification = "Confirm the common checkout form that discards working-tree changes.",
    match = ["git checkout -- README.md"],
    not_match = ["git checkout feature-branch"],
)

prefix_rule(
    pattern = ["rtk", "git", "checkout", "--"],
    decision = "prompt",
    justification = "Confirm the RTK-wrapped checkout form that discards working-tree changes.",
    match = ["rtk git checkout -- README.md"],
    not_match = ["rtk git checkout feature-branch"],
)

# Prefix rules cannot detect force flags in arbitrary later argument positions.
# These rules block the representative flag-first forms; AGENTS.md policy covers
# reordered flags and force-prefixed refspecs.
prefix_rule(
    pattern = [
        "git",
        "push",
        ["-f", "--force", "--force-with-lease", "--force-if-includes", "--mirror"],
    ],
    decision = "forbidden",
    justification = "Force pushing is prohibited; use a normal push or ask the user to perform it manually.",
    match = ["git push --force origin main"],
    not_match = [
        "git push origin main",
        "git push origin main --force",
    ],
)

prefix_rule(
    pattern = [
        "rtk",
        "git",
        "push",
        ["-f", "--force", "--force-with-lease", "--force-if-includes", "--mirror"],
    ],
    decision = "forbidden",
    justification = "RTK-wrapped force pushing is prohibited; use a normal push or ask the user to perform it manually.",
    match = ["rtk git push --force origin main"],
    not_match = [
        "rtk git push origin main",
        "rtk git push origin main --force",
    ],
)
