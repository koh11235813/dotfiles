{
    "layer": "top",
    "spacing": 0,
    "height": 0,

    "margin-top": 8,
    "margin-right": 8,
    "margin-bottom": 0,
    "margin-left": 8,

    "modules-left": [
        "clock",
	"network",
        "custom/window"

    ],

    "modules-center": [
        "hyprland/workspaces"
    ],

    "modules-right": [
        "power-profiles-daemon",
        "tray",
        "cpu",
        "memory",
        "custom/gpu-usage",
	"systemd-failed-units",
        "custom/volume-ascii",
        "custom/power-menu"
    ],

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "tooltip": false
    },

    "custom/window": {
        "exec": "/home/kinoko/.config/waybar/scripts/window_title.sh",
        "interval": 1,
	"restart-interval": 0,
	"return-type": "plain",
        "format": "{}",
	"markup":false
    },

    "tray": {
        "spacing": 10,
        "tooltip": false
    },
    "clock": {
        "format": "{:%H:%M - %a, %d %b %Y}",
        "format-alt":"{:L%A, %B %d, %Y (%R)}  ",
        "tooltip-format": "<big>{:%Y %B %d}</big>\n<tt>{calendar}</tt>",
        "tooltip": true,
        "calendar": {
            "mode"          : "year",
            "mode-mon-col"  : 3,
            "weeks-pos"     : "right",
            "on-scroll"     : 1,
            "format": {
                "months":     "<span color='#ffead3'><b>{}</b></span>",
                "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        },
        "actions":  {
            "on-click-right": "mode",
            "on-scroll-up": "tz_up",
            "on-scroll-down": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
            }
        },
    "cpu": {
        "format": "cpu {usage}%",
        "interval": 1,
        "states": {
            "critical": 90
        }
    },

    "memory": {
        "format": "mem {percentage}%",
        "interval": 2,

        "states": {
            "critical": 80
        }
    },

    "custom/gpu-usage": {
        "format": "{}",
        "exec": "~/.config/waybar/scripts/gpu_usage.sh",
        "interval": 2,
        "tooltip": false,
        "states": {
            "critical": "([7-9][0-9]%|100%)"
    }

    },


    "network": {
        "format-wifi" : "wifi ↑{bandwidthUpBits}| ↓{bandwidthDownBits}",
        "format-ethernet": "eth ↑{bandwidthUpBits} | ↓{bandwidthDownBits}",
        "format-disconnected" : "no network",
        "tooltip-format": "{ifname} via {gwaddr} 󰊗",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)   {ipaddr}/{cidr}",
	"tooltip-format-ethernet": "{ifname}   {ipaddr}/{cidr}",
	"tooltip-format-disconnected": "Disconnected",
        "interval": 1,
        "max-length": 40
    },

    "custom/volume-ascii": {
        "format": "{}",
        "exec": "~/.config/waybar/scripts/volume_ascii.sh",
        "interval": 1,
        "tooltip": false,
        "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
        "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%",
        "states": {
            "critical": "\\[.*0.*\\]",
            "warning": "\\[.*([1]?[0-9]%|20).*\\]"
        }
    },
    "power-profiles-daemon": {
        "format": "{icon} ",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "",
            "performance": "",
            "balanced": "",
            "power-saver": ""
        }
    },
    "systemd-failed-units": {
        "hide-on-ok": false, // Do not hide if there is zero failed units.
        "format": "✗ {nr_failed}",
        "format-ok": "✓",
        "system": true, // Monitor failed systemwide units.
        "user": false // Ignore failed user units.
    },
    "custom/power-menu": {
        "format": "⏻ power ",
        "on-click": "~/.config/waybar/scripts/power_menu.sh",
        "tooltip": true,
        "tooltip-format": "電源メニュー"
    }


}
